# Copy to .env.local for local dev, and set the same values in Vercel Project Settings > Environment Variables.

# MongoDB connection string (Atlas recommended for Vercel). Replace user/pass/cluster/db.
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/mango?retryWrites=true&w=majority

# Auth.js v5 session secret. Generate with: openssl rand -base64 33
AUTH_SECRET=replace-with-a-long-random-string

# Public site URL — set to your Vercel domain in production.
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# First-run seeder admin (used by `npm run seed`). Optional but recommended.
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=change-me-min-8-chars
