# MongoDB connection string (local or Atlas)
MONGODB_URI="mongodb://127.0.0.1:27017/mango"

# Auth.js secret. Generate with: npx auth secret  (or: openssl rand -base64 32)
AUTH_SECRET="replace-me-with-a-long-random-string"

# Public app base URL (used for absolute OG / sitemap URLs)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# First-run seed credentials for the Super-Admin account
SEED_ADMIN_EMAIL="admin@example.com"
SEED_ADMIN_PASSWORD="change-me-now"
